# AI Panel Studio — 环境变量配置

# DeepSeek API（可选：不配置则自动使用 mock 嘉宾生成）
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Server
PORT=3000
NODE_ENV=development

# Database (sql.js — 纯 JS/WebAssembly 实现的 SQLite，免原生编译，Windows 环境可直接运行)
DB_PATH=./data/ai-panel-studio.db
